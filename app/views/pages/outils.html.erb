<div class="hw-hero">
  <h1 class="hw-hero-title">🛠️ Outils</h1>
  <p class="hw-hero-subtitle">Ressources pour optimiser ton personnage et progresser</p>
</div>

<div class="hw-container">

  <%
    categories = [
      {
        title: "📖 Template & Theorycraft",
        color: "#64b5f6",
        sites: [
          {
            icon: "🧊",
            name: "Icy Veins",
            tag: "Template",
            desc: "Guides de classe complets, talents, stats prioritaires et rotations pour chaque spé.",
            url: "https://www.icy-veins.com/wow/"
          },
          {
            icon: "🤖",
            name: "Raidbots",
            tag: "Theorycraft",
            desc: "Simulations personnalisées pour comparer ton stuff, optimiser tes talents et valider chaque upgrade.",
            url: "https://www.raidbots.com/simbot"
          }
        ]
      },
      {
        title: "💎 BiS & Stuff",
        color: "#ce93d8",
        sites: [
          {
            icon: "🩸",
            name: "Bloodmallet",
            tag: "BiS Trinkets",
            desc: "Classement des trinkets par spé avec simulations automatiques. Identifie les meilleures options pour ton rôle.",
            url: "https://bloodmallet.com/"
          },
          {
            icon: "❔",
            name: "QE Live",
            tag: "BiS Healers",
            desc: "Outil BiS spécialisé pour les healers. Compare trinkets, sets et stats avec une précision maximale.",
            url: "https://questionablyepic.com/live/"
          },
          {
            icon: "🏛️",
            name: "Archon.gg",
            tag: "Stuff populaire",
            desc: "Analyse des builds et équipements les plus joués par les meilleurs joueurs. Tendances par spé en temps réel.",
            url: "https://www.archon.gg/wow"
          }
        ]
      },
      {
        title: "📊 Logs & Actus",
        color: "#ef9a9a",
        sites: [
          {
            icon: "📋",
            name: "Warcraft Logs",
            tag: "Logs de raid",
            desc: "Analyse tes logs en détail. Parses, rankings mondiaux et comparaisons de performances.",
            url: "https://www.warcraftlogs.com/"
          },
          {
            icon: "📰",
            name: "Wowhead",
            tag: "Patch Notes",
            desc: "Base de données complète, patch notes, guides de donjons et toute l'actualité de World of Warcraft.",
            url: "https://www.wowhead.com/"
          }
        ]
      }
    ]
  %>

  <% categories.each do |cat| %>
    <div style="margin-bottom: 48px;">

      <!-- Titre de section -->
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.07);">
        <div style="width: 4px; height: 20px; background: <%= cat[:color] %>; border-radius: 2px; flex-shrink: 0;"></div>
        <h2 style="font-family: 'Cinzel', serif; font-size: 14px; font-weight: 700; color: #f0e6d3; margin: 0; text-transform: uppercase; letter-spacing: 1.5px;"><%= cat[:title] %></h2>
      </div>

      <!-- Grille des cartes -->
      <div class="hw-main-grid">
        <% cat[:sites].each do |site| %>
          <a href="<%= site[:url] %>" target="_blank" rel="noopener" style="text-decoration: none; color: inherit; display: block;">
            <div class="hw-card" style="height: 100%; border-top: 3px solid <%= cat[:color] %>; display: flex; flex-direction: column;">

              <div class="hw-card-header" style="gap: 16px;">
                <span style="font-size: 1.8rem; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.04); border-radius: 10px; border: 1px solid rgba(255,255,255,0.08); flex-shrink: 0;">
                  <%= site[:icon] %>
                </span>
                <div>
                  <div class="hw-card-title" style="margin-bottom: 5px;"><%= site[:name] %></div>
                  <span style="font-size: 10px; font-weight: 600; color: <%= cat[:color] %>; background: <%= cat[:color] %>1a; border: 1px solid <%= cat[:color] %>33; border-radius: 4px; padding: 2px 8px; text-transform: uppercase; letter-spacing: 0.5px;">
                    <%= site[:tag] %>
                  </span>
                </div>
              </div>

              <div class="hw-card-body" style="flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                <p style="color: #888; font-size: 13px; line-height: 1.6; margin: 0 0 20px 0;"><%= site[:desc] %></p>
                <div style="display: flex; align-items: center; justify-content: space-between;">
                  <span style="font-size: 11px; color: #555; text-transform: uppercase; letter-spacing: 0.8px; font-weight: 700;">Ouvrir</span>
                  <span style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.25); color: #ffd700; display: flex; align-items: center; justify-content: center; font-size: 14px;">→</span>
                </div>
              </div>

            </div>
          </a>
        <% end %>
      </div>

    </div>
  <% end %>

</div>
