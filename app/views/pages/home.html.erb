<!-- Hero -->
<div class="hw-hero">
  <%= image_tag "logo.png", class: "hw-hero-logo", alt: "Highway to Wipe" %>
  <h1 class="hw-hero-title">Highway to Wipe</h1>
  <p class="hw-hero-subtitle">Guilde PvE • Alliance • Eitrigg</p>
</div>

<div class="hw-container">

  <!-- Grille principale : Progression + Prochain Event -->
  <div class="hw-main-grid">

<!-- PROGRESSION MULTI-RAIDS -->
<div class="hw-card">
  <div class="hw-card-header">
    <span class="hw-card-icon">⚔️</span>
    <h2 class="hw-card-title">Progression Raids</h2>
    <% if @latest_report_code.present? %>
      <a href="https://www.warcraftlogs.com/reports/<%= @latest_report_code %>"
         target="_blank" rel="noopener" class="hw-wcl-btn">
        📋 Derniers logs →
      </a>
    <% else %>
      <a href="https://www.warcraftlogs.com/guild/eu/eitrigg/highway%20to%20wipe"
         target="_blank" rel="noopener" class="hw-wcl-btn">
        📋 Logs WCL →
      </a>
    <% end %>
  </div>
  <div class="hw-card-body">
    <% @warcraftlogs_progression.each do |raid_name, prog| %>
      <div class="hw-prog-main" style="margin-bottom: 20px;">

        <div class="hw-prog-difficulty-name" style="color: #ffd700; margin-bottom: 6px;">
          <%= raid_name %>
        </div>

        <%
          highest = nil
          if prog[:mythic][:killed] > 0
            highest = { label: "Mythique", killed: prog[:mythic][:killed], total: prog[:mythic][:total], color: "#f44336" }
          elsif prog[:heroic][:killed] > 0
            highest = { label: "Héroïque", killed: prog[:heroic][:killed], total: prog[:heroic][:total], color: "#2196f3" }
          elsif prog[:normal][:killed] > 0
            highest = { label: "Normal", killed: prog[:normal][:killed], total: prog[:normal][:total], color: "#4caf50" }
          end
        %>

        <% if highest %>
          <div class="hw-prog-difficulty-name" style="color: <%= highest[:color] %>">
            <%= highest[:label] %>
          </div>
          <div class="hw-prog-score">
            <span class="hw-prog-killed"><%= highest[:killed] %></span>
            <span class="hw-prog-sep">/</span>
            <span class="hw-prog-total"><%= highest[:total] %></span>
          </div>
          <div class="hw-prog-bar">
            <div class="hw-prog-fill" style="width: <%= (highest[:killed].to_f / highest[:total] * 100).round %>%; background: <%= highest[:color] %>;"></div>
          </div>
        <% else %>
          <div class="hw-prog-score">
            <span class="hw-prog-killed">0</span>
            <span class="hw-prog-sep">/</span>
            <span class="hw-prog-total"><%= prog[:total] %></span>
          </div>
          <div class="hw-prog-bar">
            <div class="hw-prog-fill" style="width: 0%;"></div>
          </div>
        <% end %>

      </div>
      <% unless raid_name == @warcraftlogs_progression.keys.last %>
        <hr style="border-color: rgba(255,215,0,0.15); margin: 16px 0;">
      <% end %>
    <% end %>
  </div>
</div>

    <!-- PROCHAIN EVENT -->
    <% if @next_event.present? %>
      <div class="hw-card hw-event-card">
        <div class="hw-card-header">
          <span class="hw-card-icon">📅</span>
          <h2 class="hw-card-title">Prochain Event</h2>
        </div>
        <div class="hw-card-body">
          <div class="hw-event-content">
            <span class="hw-event-icon-main"><%= @next_event.event_type_emoji %></span>
            <div class="hw-event-main">
              <div class="hw-event-name"><%= @next_event.title %></div>
              <div class="hw-event-datetime">
                <%= @next_event.start_time.strftime("%d %B") %> • <%= @next_event.start_time.strftime("%Hh%M") %>
              </div>
            </div>
            <div class="hw-event-participants-compact">
              <span class="hw-event-part-num"><%= @next_event_participants %></span> inscrit<%= @next_event_participants > 1 ? 's' : '' %>
            </div>
            <%= link_to event_path(@next_event), class: "hw-event-btn-round" do %>
              →
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="hw-card">
        <div class="hw-card-header">
          <span class="hw-card-icon">📅</span>
          <h2 class="hw-card-title">Prochain Event</h2>
        </div>
        <div class="hw-card-body">
          <p class="hw-empty">Aucun événement prévu</p>
        </div>
      </div>
    <% end %>

  </div>

  <!-- Grille activité : Kills + M+ + Deaths -->
  <div class="hw-activity-grid">

    <!-- KILLS RÉCENTS -->
    <div class="hw-card">
      <div class="hw-card-header">
        <span class="hw-card-icon">🏆</span>
        <h3 class="hw-card-title">Kills Récents</h3>
      </div>
      <div class="hw-card-body hw-card-list">
        <% if @warcraftlogs_recent_kills.any? %>
          <% @warcraftlogs_recent_kills.first(5).each do |kill| %>
            <div class="hw-list-item">
              <div class="hw-list-icon">💀</div>
              <div class="hw-list-content">
                <div class="hw-list-name"><%= kill[:boss] %></div>
                <div class="hw-list-detail"><%= kill[:difficulty] %> • <%= kill[:date].strftime("%d/%m") %></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="hw-empty">Aucun kill récent</p>
        <% end %>
      </div>
    </div>

    <!-- TOP MYTHIC+ -->
    <div class="hw-card">
      <div class="hw-card-header">
        <span class="hw-card-icon">🔑</span>
        <h3 class="hw-card-title">Top Mythic+</h3>
      </div>
      <div class="hw-card-body hw-card-list">
        <% if @raiderio_top_players.any? %>
          <% @raiderio_top_players.first(5).each_with_index do |player, index| %>
            <div class="hw-list-item">
              <div class="hw-list-rank">#<%= index + 1 %></div>
              <div class="hw-list-content">
                <div class="hw-list-name"><%= player[:name] %></div>
                <div class="hw-list-detail"><%= player[:class] %> <%= player[:spec] %></div>
              </div>
              <div class="hw-list-score" style="color: #64b5f6;"><%= player[:score] %></div>
            </div>
          <% end %>
        <% else %>
          <p class="hw-empty">Aucune donnée M+</p>
        <% end %>
      </div>
    </div>

    <!-- WALL OF SHAME -->
    <div class="hw-card">
      <div class="hw-card-header">
        <span class="hw-card-icon">💀</span>
        <h3 class="hw-card-title">Wall of Shame</h3>
      </div>
      <div class="hw-card-body hw-card-list">
        <% if @warcraftlogs_death_stats.any? %>
          <% @warcraftlogs_death_stats.first(5).each_with_index do |player, index| %>
            <div class="hw-list-item">
              <div class="hw-list-rank">#<%= index + 1 %></div>
              <div class="hw-list-content">
                <div class="hw-list-name"><%= player[:player] %></div>
                <div class="hw-list-detail"><%= player[:class] %></div>
              </div>
              <div class="hw-list-score" style="color: #e57373;"><%= player[:deaths] %> 💀</div>
            </div>
          <% end %>
        <% else %>
          <p class="hw-empty">Aucune donnée</p>
        <% end %>
      </div>
    </div>

  </div>

</div>

<!-- À propos -->
<div class="hw-about">
  <div class="hw-container">
    <h2 class="hw-about-title">À propos</h2>
    <p class="hw-about-text">
      Highway to Wipe est une guilde PvE sur le serveur Eitrigg.
      On raid dans la bonne humeur tout en visant le contenu endgame.
    </p>
  </div>
</div>
